# Application Configuration
APP_NAME=Event Lifecycle Agent
APP_VERSION=1.0.0
DEBUG=True

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=event_lifecycle
DB_USER=postgres
DB_PASSWORD=postgres

# Security
SECRET_KEY=your-secret-key-change-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@eventengine.com

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI Configuration (for insights service - Stage 5)
OPENAI_API_KEY=your-openai-api-key
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# Agent Configuration
AGENT_LOOP_INTERVAL_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/event_agent.log
